# SafeNet-AI Backend Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI API Key (for AI chatbot and analysis)
OPENAI_API_KEY=your_openai_api_key_here

# VirusTotal API Key (URL scanning)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Google Safe Browsing API Key (URL reputation)
GOOGLE_SAFE_BROWSING_KEY=your_google_safebrowsing_key_here

# Shodan API Key (Internet-connected device intelligence)
SHODAN_API_KEY=your_shodan_api_key_here

# AbuseIPDB API Key (IP reputation)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# HaveIBeenPwned (password breach checking - free k-anonymity endpoint)
HIBP_API_KEY=

# Database URL (default: SQLite, change to PostgreSQL as needed)
DATABASE_URL=sqlite+aiosqlite:///./safenet.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/safenet

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
